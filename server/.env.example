PORT=8080

# PostgreSQL (matches server/docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=messenger
DB_PASSWORD=your_secure_password_123
DB_NAME=messenger_db

# Redis (matches server/docker-compose.yml)
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# SMTP (optional, can be empty for mock emails)
SMTP_HOST=
SMTP_PORT=465
SMTP_FROM=
SMTP_PASSWORD=
SMTP_FROM_NAME=Messenger

# S3/MinIO (optional)
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
